<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>

<HBox prefHeight="450.0" prefWidth="800.0" xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml" fx:controller="controllers.LoginController"
      stylesheets="@style.css">

   <VBox alignment="CENTER" prefWidth="380.0" styleClass="login-sidebar" HBox.hgrow="ALWAYS" spacing="20">
      <ImageView fitHeight="150.0" fitWidth="150.0" preserveRatio="true">
         <image>
            <Image url="@logo.png" />
         </image>
      </ImageView>
      <Label text="HỆ THỐNG ĐẤU GIÁ" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: white;"/>
      <Label text="1388AUCTION System" style="-fx-text-fill: white; -fx-opacity: 0.8;"/>
   </VBox>

   <VBox alignment="CENTER" prefWidth="420.0" spacing="20.0" style="-fx-background-color: white;">
      <padding>
         <Insets left="40.0" right="40.0" />
      </padding>

      <VBox alignment="CENTER" spacing="10">
         <Label text="👤" style="-fx-font-size: 50px; -fx-text-fill: #3498db;"/>
         <Label text="Welcome Back 1388AUCTION" wrapText="true" textAlignment="CENTER"
                style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
      </VBox>

      <VBox spacing="15.0">
         <TextField fx:id="usernameField" promptText="Tên đăng nhập" styleClass="login-input" prefHeight="45"/>
         <PasswordField fx:id="passwordField" promptText="Mật khẩu" styleClass="login-input" prefHeight="45"/>
      </VBox>

      <Button fx:id="loginButton" text="ĐĂNG NHẬP" onAction="#handleLogin"
              prefWidth="Infinity" prefHeight="45.0" styleClass="login-btn-sync" />

      <Label text="Quên mật khẩu?" style="-fx-text-fill: #7f8c8d; -fx-cursor: hand;"/>
   </VBox>
</HBox>