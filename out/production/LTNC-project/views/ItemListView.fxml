<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox prefHeight="600.0" prefWidth="900.0" spacing="20.0" style="-fx-background-color: #f5f6fa;"
      xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="controllers.ItemListController" stylesheets="@style.css">

    <padding>
        <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="15.0">
        <Label text="📦" style="-fx-font-size: 30px;"/>
        <VBox>
            <Label text="DANH SÁCH ĐẤU GIÁ" styleClass="header-title"/>
            <Label text="Quản lý sản phẩm hệ thống 1388" style="-fx-text-fill: #7f8c8d;"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS" />
        <Button text="+ Thêm mới" styleClass="login-btn-sync" prefHeight="40" prefWidth="120"/>
    </HBox>

    <TableView fx:id="itemTable" VBox.vgrow="ALWAYS" styleClass="modern-table">
        <columns>
            <TableColumn fx:id="idColumn" prefWidth="100.0" text="ID" />
            <TableColumn fx:id="nameColumn" prefWidth="300.0" text="Tên Sản Phẩm" />
            <TableColumn fx:id="priceColumn" prefWidth="200.0" text="Giá hiện tại" />
            <TableColumn fx:id="statusColumn" prefWidth="200.0" text="Trạng thái" />
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
    </TableView>
</VBox>