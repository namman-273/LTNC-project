<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.ItemListController"
            stylesheets="@style.css"
            prefHeight="500.0" prefWidth="700.0">

    <VBox spacing="20.0" AnchorPane.topAnchor="0.0" AnchorPane.bottomAnchor="0.0"
          AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">

        <padding>
            <Insets top="25" right="25" bottom="25" left="25"/>
        </padding>

        <Label text="HỆ THỐNG QUẢN LÝ ĐẤU GIÁ"
               style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2980b9;"/>

        <TableView fx:id="itemTable" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="nameColumn" text="Tên sản phẩm" prefWidth="300.0" />
                <TableColumn fx:id="priceColumn" text="Giá khởi điểm" prefWidth="200.0" />
            </columns>
        </TableView>

        <HBox spacing="15.0" alignment="CENTER_RIGHT">
            <Button text="Làm mới" prefWidth="100.0" />
            <Button text="Xóa sản phẩm" prefWidth="120.0" style="-fx-background-color: #e74c3c;" />
            <Button text="Thêm sản phẩm" prefWidth="150.0" />
        </HBox>

    </VBox>
</AnchorPane>