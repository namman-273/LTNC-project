<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.geometry.Insets?>

<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.auction.controllers.LoginController"
      prefWidth="720" prefHeight="520"
      stylesheets="@style.css">

    <!-- CỘT TRÁI: gradient xanh navy -->
    <VBox prefWidth="300" prefHeight="520" alignment="CENTER" spacing="20"
          style="-fx-background-color: linear-gradient(to bottom, #1E3A6E, #2196F3);">
        <padding><Insets top="50" right="30" bottom="50" left="30"/></padding>

        <Label text="🏛️" style="-fx-font-size: 56px;"/>

        <VBox alignment="CENTER" spacing="6">
            <Label text="AUCTIVA"
                   style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: white; -fx-letter-spacing: 3;"/>
            <Label text="LIVE ONLINE AUCTIONS"
                   style="-fx-font-size: 10px; -fx-text-fill: #90CAF9; -fx-letter-spacing: 1;"/>
        </VBox>

        <Region prefHeight="20"/>

        <VBox spacing="12" alignment="CENTER">
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="✓" style="-fx-text-fill: #90CAF9; -fx-font-size: 13px;"/>
                <Label text="Đấu giá trực tuyến minh bạch"
                       style="-fx-text-fill: #E3F2FD; -fx-font-size: 12px;"/>
            </HBox>
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="✓" style="-fx-text-fill: #90CAF9; -fx-font-size: 13px;"/>
                <Label text="Realtime - cập nhật tức thì"
                       style="-fx-text-fill: #E3F2FD; -fx-font-size: 12px;"/>
            </HBox>
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="✓" style="-fx-text-fill: #90CAF9; -fx-font-size: 13px;"/>
                <Label text="Bảo mật và an toàn"
                       style="-fx-text-fill: #E3F2FD; -fx-font-size: 12px;"/>
            </HBox>
        </VBox>
    </VBox>

    <!-- CỘT PHẢI: form đăng nhập -->
    <VBox prefWidth="420" prefHeight="520" alignment="CENTER" spacing="14"
          style="-fx-background-color: white;">
        <padding><Insets top="50" right="48" bottom="50" left="48"/></padding>

        <!-- Logo nhỏ -->
        <HBox alignment="CENTER" spacing="10">
            <Label text="🏛️" style="-fx-font-size: 24px;"/>
            <VBox spacing="1">
                <Label text="AUCTIVA"
                       style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1E3A6E;"/>
                <Label text="LIVE ONLINE AUCTIONS"
                       style="-fx-font-size: 8px; -fx-text-fill: #888;"/>
            </VBox>
        </HBox>

        <Region prefHeight="6"/>

        <Label text="Chào mừng trở lại!"
               style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1E3A6E;"/>
        <Label text="Đăng nhập để tiếp tục đấu giá"
               style="-fx-font-size: 12px; -fx-text-fill: #888;"/>

        <Region prefHeight="8"/>

        <!-- Username -->
        <VBox spacing="5">
            <Label text="Tên đăng nhập"
                   style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #444;"/>
            <TextField fx:id="usernameField" promptText="Nhập tên đăng nhập..."
                       prefHeight="42" prefWidth="324"
                       styleClass="text-field-modern"/>
        </VBox>

        <!-- Password -->
        <VBox spacing="5">
            <Label text="Mật khẩu"
                   style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #444;"/>
            <PasswordField fx:id="passwordField" promptText="••••••••"
                           prefHeight="42" prefWidth="324"
                           styleClass="text-field-modern"/>
        </VBox>

        <!-- Error -->
        <Label fx:id="errorLabel" text=""
               style="-fx-text-fill: #E53935; -fx-font-size: 12px;"
               wrapText="true" maxWidth="324"/>

        <!-- Nút đăng nhập -->
        <Button fx:id="loginButton" text="ĐĂNG NHẬP"
                prefWidth="324" prefHeight="44"
                onAction="#handleLogin"
                styleClass="btn-primary"
                style="-fx-font-size: 14px;"/>

        <!-- Đăng ký -->
        <Button text="Chưa có tài khoản? Đăng ký ngay →"
                onAction="#handleRegister"
                prefWidth="324" prefHeight="36"
                style="-fx-background-color: #F0F7FF; -fx-text-fill: #2196F3;
                       -fx-font-size: 12px; -fx-cursor: hand;
                       -fx-background-radius: 10; -fx-font-weight: bold;"/>

    </VBox>

</HBox>