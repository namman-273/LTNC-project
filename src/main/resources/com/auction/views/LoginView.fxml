<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.geometry.Insets?>

<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.auction.controllers.LoginController"
      prefWidth="700" prefHeight="450">

    <!-- CỘT TRÁI: xanh -->
    <VBox prefWidth="320" prefHeight="450" alignment="CENTER" spacing="15"
          style="-fx-background-color: #2196F3;">
        <padding><Insets top="40" right="30" bottom="40" left="30"/></padding>

        <Label text="HỆ THỐNG ĐẤU GIÁ"
               style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: white;"/>
        <Label text="1388AUCTION System"
               style="-fx-font-size: 13px; -fx-text-fill: #e0f0ff;"/>
    </VBox>

    <!-- CỘT PHẢI: trắng -->
    <VBox prefWidth="380" prefHeight="450" alignment="CENTER" spacing="15"
          style="-fx-background-color: white;">
        <padding><Insets top="50" right="40" bottom="50" left="40"/></padding>

        <Label text="Welcome Back"
               style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2196F3;"/>

        <TextField fx:id="usernameField" promptText="Tên đăng nhập"
                   prefHeight="40"
                   style="-fx-border-color: #cccccc; -fx-border-radius: 5; -fx-background-radius: 5; -fx-font-size: 13px;"/>

        <PasswordField fx:id="passwordField" promptText="Mật khẩu"
                       prefHeight="40"
                       style="-fx-border-color: #cccccc; -fx-border-radius: 5; -fx-background-radius: 5; -fx-font-size: 13px;"/>

        <Label fx:id="errorLabel" text=""
               style="-fx-text-fill: red; -fx-font-size: 12px;"/>

        <Button fx:id="loginButton" text="ĐĂNG NHẬP"
                prefWidth="300" prefHeight="43"
                onAction="#handleLogin"
                style="-fx-background-color: #2196F3; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 5;"/>

        <Label text="Quên mật khẩu?"
               style="-fx-text-fill: #888888; -fx-font-size: 12px;"/>
        <Button text="Chưa có tài khoản? Đăng ký" onAction="#handleRegister"
                prefWidth="300" prefHeight="35"
                style="-fx-background-color: transparent; -fx-text-fill: #2196F3; -fx-font-size: 12px;"/>       
    </VBox>

</HBox>