<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.geometry.Insets?>


<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.auction.controllers.AuctionListController"
      prefWidth="700" prefHeight="500" spacing="15"
      style="-fx-background-color: #f5f5f5;">
    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

    <!-- HEADER -->
    <HBox alignment="CENTER_LEFT" spacing="10"
          style="-fx-background-color: #2196F3; -fx-background-radius: 8;"
          prefHeight="60">
        <padding><Insets top="10" right="20" bottom="10" left="20"/></padding>
        <Label text="🏛️ HỆ THỐNG ĐẤU GIÁ"
               style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;"/>
        <HBox HBox.hgrow="ALWAYS"/>
        <Label fx:id="welcomeLabel" text="Xin chào!"
               style="-fx-font-size: 13px; -fx-text-fill: white;"/>
        <Button text="Đăng xuất" onAction="#handleLogout"
                style="-fx-background-color: white; -fx-text-fill: #2196F3; -fx-font-weight: bold; -fx-background-radius: 5;"/>
    </HBox>

    <!-- BẢNG DANH SÁCH -->
    <TableView fx:id="auctionTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="idCol" text="ID" prefWidth="80"/>
            <TableColumn fx:id="nameCol" text="Tên sản phẩm" prefWidth="220"/>
            <TableColumn fx:id="priceCol" text="Giá hiện tại" prefWidth="150"/>
            <TableColumn fx:id="statusCol" text="Trạng thái" prefWidth="120"/>
        </columns>
    </TableView>

    <!-- NÚT BÊN DƯỚI -->
    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="➕ Tạo phiên" onAction="#handleCreateAuction"
                prefHeight="35" prefWidth="130"
                style="-fx-background-color: #FF9800; -fx-text-fill: white; -fx-background-radius: 5;"/>
        <Button text="🔄 Làm mới" onAction="#handleRefresh"
                prefHeight="35" prefWidth="120"
                style="-fx-background-color: #2196F3; -fx-text-fill: white; -fx-background-radius: 5;"/>
        <Button text="👁 Xem chi tiết" onAction="#handleViewDetail"
                prefHeight="35" prefWidth="140"
                style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-background-radius: 5;"/>
    </HBox>

</VBox>