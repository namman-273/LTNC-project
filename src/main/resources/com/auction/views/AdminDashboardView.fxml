<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.auction.controllers.AdminDashboardController"
      prefWidth="750" prefHeight="550" spacing="15"
      style="-fx-background-color: #f5f5f5;">
    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

    <HBox alignment="CENTER_LEFT" spacing="10"
          style="-fx-background-color: #e53935; -fx-background-radius: 8;"
          prefHeight="60">
        <padding><Insets top="10" right="20" bottom="10" left="20"/></padding>
        <Button text="← Quay lại" onAction="#handleBack"
                style="-fx-background-color: white; -fx-text-fill: #e53935; -fx-font-weight: bold; -fx-background-radius: 5;"/>
        <Label text="⚙️ ADMIN DASHBOARD"
               style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: white;"/>
        <HBox HBox.hgrow="ALWAYS"/>
        <Button text="🔄 Làm mới" onAction="#handleRefresh"
                style="-fx-background-color: white; -fx-text-fill: #e53935; -fx-font-weight: bold; -fx-background-radius: 5;"/>
    </HBox>

    <TableView fx:id="auctionTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="idCol" text="ID" prefWidth="200"/>
            <TableColumn fx:id="nameCol" text="Tên sản phẩm" prefWidth="180"/>
            <TableColumn fx:id="priceCol" text="Giá hiện tại" prefWidth="150"/>
            <TableColumn fx:id="statusCol" text="Trạng thái" prefWidth="100"/>
        </columns>
    </TableView>

    <Label fx:id="messageLabel" text=""
           style="-fx-font-size: 12px;" wrapText="true"/>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="🔴 Kết thúc phiên" onAction="#handleEndAuction"
                prefHeight="38" prefWidth="160"
                style="-fx-background-color: #e53935; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5;"/>
        <Button text="➕ Tạo phiên mới" onAction="#handleCreateAuction"
                prefHeight="38" prefWidth="160"
                style="-fx-background-color: #2196F3; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5;"/>
    </HBox>

</VBox>