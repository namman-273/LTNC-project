<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ListView?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.auction.controllers.BidController"
      prefWidth="800" prefHeight="600" spacing="0"
      stylesheets="@style.css"
      style="-fx-background-color: #F8F9FA;">

    <!-- HEADER -->
    <HBox alignment="CENTER_LEFT" spacing="14"
          style="-fx-background-color: linear-gradient(to right, #1565C0, #2196F3);
                 -fx-padding: 0 24; -fx-pref-height: 60;
                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 8, 0, 0, 3);">

        <Button text="← Quay lại" onAction="#handleBack"
                style="-fx-background-color: rgba(255,255,255,0.15);
                       -fx-text-fill: white; -fx-font-size: 12px;
                       -fx-background-radius: 8; -fx-cursor: hand;
                       -fx-border-color: rgba(255,255,255,0.4);
                       -fx-border-radius: 8; -fx-border-width: 1;
                       -fx-padding: 6 14;"/>

        <Label fx:id="auctionTitleLabel" text="Phiên đấu giá"
               style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: white;"
               maxWidth="500"/>
    </HBox>

    <!-- CONTENT -->
    <HBox spacing="16" VBox.vgrow="ALWAYS">
        <padding><Insets top="16" right="20" bottom="16" left="20"/></padding>

        <!-- TRÁI -->
        <VBox spacing="14" prefWidth="360" VBox.vgrow="ALWAYS">

            <!-- Thông tin sản phẩm -->
            <VBox spacing="10" styleClass="card">
                <Label text="📦 Thông tin sản phẩm"
                       style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1565C0;"/>

                <HBox spacing="8" alignment="CENTER_LEFT">
                    <Label text="Tên:" style="-fx-font-size: 12px; -fx-text-fill: #888; -fx-min-width: 80;"/>
                    <Label fx:id="itemNameLabel" text="---"
                           style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #333;"
                           wrapText="true"/>
                </HBox>

                <HBox spacing="8" alignment="CENTER_LEFT">
                    <Label text="Giá hiện tại:" style="-fx-font-size: 12px; -fx-text-fill: #888; -fx-min-width: 80;"/>
                    <Label fx:id="currentPriceLabel" text="---"
                           style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2196F3;"
                           wrapText="true" maxWidth="240"/>
                </HBox>

                <HBox spacing="8" alignment="CENTER_LEFT">
                    <Label text="Trạng thái:" style="-fx-font-size: 12px; -fx-text-fill: #888; -fx-min-width: 80;"/>
                    <Label fx:id="statusLabel" text="---"
                           style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #43A047;"/>
                </HBox>

                <Label fx:id="messageLabel" text=""
                       style="-fx-font-size: 12px;" wrapText="true" maxWidth="320"/>
            </VBox>

            <!-- Lịch sử -->
            <VBox spacing="8" VBox.vgrow="ALWAYS" styleClass="card">
                <Label text="📋 Lịch sử đặt giá"
                       style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1565C0;"/>
                <ListView fx:id="bidHistoryList" VBox.vgrow="ALWAYS"
                          styleClass="list-view"/>
            </VBox>
        </VBox>

        <!-- PHẢI -->
        <VBox spacing="14" prefWidth="380" VBox.vgrow="ALWAYS">

            <!-- Đặt giá -->
            <VBox spacing="12" styleClass="card">
                <Label text="🔨 Đặt giá"
                       style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1565C0;"/>

                <VBox spacing="5">
                    <Label text="Nhập giá của bạn (VND):"
                           style="-fx-font-size: 12px; -fx-text-fill: #666;"/>
                    <TextField fx:id="bidAmountField" promptText="Nhập số tiền..."
                               prefHeight="42" styleClass="text-field-modern"/>
                    <Label text="Giá đặt phải cao hơn giá hiện tại"
                           style="-fx-font-size: 11px; -fx-text-fill: #AAAAAA;"/>
                </VBox>

                <Button text="🔨 ĐẶT GIÁ NGAY" onAction="#handleBid"
                        prefWidth="348" prefHeight="44"
                        styleClass="btn-danger"
                        style="-fx-font-size: 14px; -fx-font-weight: bold;"/>

                <Button text="📊 Xem biểu đồ giá" onAction="#handleViewChart"
                        prefWidth="348" prefHeight="38"
                        styleClass="btn-outline"/>
            </VBox>

            <!-- Hướng dẫn -->
            <VBox spacing="10" styleClass="card"
                  style="-fx-background-color: #E8F5E9;
                         -fx-border-color: #A5D6A7;
                         -fx-border-radius: 12; -fx-border-width: 1;">
                <Label text="💡 Hướng dẫn"
                       style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #2E7D32;"/>
                <Label text="• Nhập giá cao hơn giá hiện tại"
                       style="-fx-font-size: 12px; -fx-text-fill: #388E3C;" wrapText="true"/>
                <Label text="• Giá cập nhật tự động realtime"
                       style="-fx-font-size: 12px; -fx-text-fill: #388E3C;" wrapText="true"/>
                <Label text="• Người đặt cao nhất khi hết thời gian thắng"
                       style="-fx-font-size: 12px; -fx-text-fill: #388E3C;" wrapText="true"/>
            </VBox>

        </VBox>
    </HBox>

</VBox>