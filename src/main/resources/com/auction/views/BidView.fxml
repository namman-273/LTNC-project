<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ListView?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.auction.controllers.BidController"
      prefWidth="700" prefHeight="550" spacing="15"
      style="-fx-background-color: #f5f5f5;">
    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

    <!-- HEADER -->
    <HBox alignment="CENTER_LEFT" spacing="10"
          style="-fx-background-color: #2196F3; -fx-background-radius: 8;"
          prefHeight="60">
        <padding><Insets top="10" right="20" bottom="10" left="20"/></padding>
        <Button text="← Quay lại" onAction="#handleBack"
                style="-fx-background-color: white; -fx-text-fill: #2196F3; -fx-font-weight: bold; -fx-background-radius: 5;"/>
        <Label fx:id="auctionTitleLabel" text="Phiên đấu giá"
               style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: white;"/>
    </HBox>

    <!-- THÔNG TIN SẢN PHẨM -->
    <HBox spacing="20">

        <!-- TRÁI: thông tin -->
        <VBox spacing="10" prefWidth="320"
              style="-fx-background-color: white; -fx-background-radius: 8; -fx-padding: 15;">
            <Label text="Thông tin sản phẩm"
                   style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
            <Label fx:id="itemNameLabel" text="Tên: ---"
                   style="-fx-font-size: 13px;"/>
            <Label fx:id="currentPriceLabel" text="Giá hiện tại: ---"
                   style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #e74c3c;"/>
            <Label fx:id="statusLabel" text="Trạng thái: ---"
                   style="-fx-font-size: 13px;"/>
            <Label fx:id="messageLabel" text=""
                   style="-fx-font-size: 12px;"/>
        </VBox>

        <!-- PHẢI: đặt giá -->
        <VBox spacing="10" prefWidth="320"
              style="-fx-background-color: white; -fx-background-radius: 8; -fx-padding: 15;">
            <Label text="Đặt giá"
                   style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
            <TextField fx:id="bidAmountField" promptText="Nhập giá của bạn..."
                       prefHeight="40"
                       style="-fx-border-color: #cccccc; -fx-border-radius: 5; -fx-background-radius: 5;"/>
            <Button text="🔨 ĐẶT GIÁ" onAction="#handleBid"
                    prefWidth="280" prefHeight="43"
                    style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 5;"/>
            <Button text="📊 Xem biểu đồ" onAction="#handleViewChart"
                    prefWidth="280" prefHeight="38"
                    style="-fx-background-color: #9C27B0; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 5;"/>
        </VBox>

    </HBox>

    <!-- LỊCH SỬ ĐẶT GIÁ -->
    <VBox spacing="5" VBox.vgrow="ALWAYS"
          style="-fx-background-color: white; -fx-background-radius: 8; -fx-padding: 15;">
        <Label text="📋 Lịch sử đặt giá"
               style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
        <ListView fx:id="bidHistoryList" VBox.vgrow="ALWAYS"/>
    </VBox>

</VBox>