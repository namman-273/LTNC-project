<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.chart.LineChart?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.auction.controllers.BidChartController"
      prefWidth="700" prefHeight="500" spacing="15"
      style="-fx-background-color: #f5f5f5;">
    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

    <!-- HEADER -->
    <HBox alignment="CENTER_LEFT" spacing="10"
          style="-fx-background-color: #2196F3; -fx-background-radius: 8;"
          prefHeight="55">
        <padding><Insets top="10" right="20" bottom="10" left="20"/></padding>
        <Button text="← Quay lại" onAction="#handleBack"
                style="-fx-background-color: white; -fx-text-fill: #2196F3; -fx-font-weight: bold; -fx-background-radius: 5;"/>
        <Label fx:id="titleLabel" text="Biểu đồ giá đấu giá"
               style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: white;"/>
    </HBox>

    <!-- CHART -->
    <LineChart fx:id="bidChart" VBox.vgrow="ALWAYS"
               animated="true"
               style="-fx-background-color: white; -fx-background-radius: 8;">
        <xAxis>
            <NumberAxis fx:id="xAxis" label="Lần đặt giá" autoRanging="true"/>
        </xAxis>
        <yAxis>
            <NumberAxis fx:id="yAxis" label="Giá (VND)" autoRanging="true"/>
        </yAxis>
    </LineChart>

</VBox>