<?xml version="1.0"?>
<!DOCTYPE module PUBLIC "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
    "https://checkstyle.org/dtds/configuration_1_3.dtd">

<module name="Checker">
    <property name="severity" value="warning"/>
    <property name="fileExtensions" value="java"/>

    <!-- Không dùng tab, phải dùng space -->
    <module name="FileTabCharacter">
        <property name="eachLine" value="true"/>
    </module>

    <!-- Mỗi file phải kết thúc bằng newline -->
    <module name="NewlineAtEndOfFile"/>

    <module name="TreeWalker">

        <!-- ==================== NAMING CONVENTIONS ==================== -->
        <module name="ConstantName"/>
        <module name="LocalVariableName"/>
        <module name="MethodName"/>
        <module name="PackageName"/>
        <module name="ParameterName"/>
        <module name="TypeName"/>
        <module name="MemberName"/>
        <module name="StaticVariableName"/>

        <!-- ==================== IMPORTS ==================== -->
        <!-- Không được import * (wildcard) -->
        <module name="AvoidStarImport"/>
        <!-- Không được import thứ không dùng -->
        <module name="UnusedImports"/>
        <!-- Không import class trùng tên với java.lang -->
        <module name="IllegalImport"/>
        <!-- Không import dư thừa (chính lớp của mình) -->
        <module name="RedundantImport"/>

        <!-- ==================== SIZE / LENGTH ==================== -->
        <!-- Mỗi dòng tối đa 120 ký tự -->
        <module name="LineLength">
            <property name="max" value="120"/>
            <property name="ignorePattern" value="^package.*|^import.*|a href|href|http://|https://|ftp://"/>
        </module>
        <!-- Method không quá 60 dòng -->
        <module name="MethodLength">
            <property name="max" value="60"/>
        </module>
        <!-- Số tham số method tối đa 7 -->
        <module name="ParameterNumber">
            <property name="max" value="7"/>
        </module>

        <!-- ==================== WHITESPACE ==================== -->
        <module name="WhitespaceAround">
            <property name="tokens" value="ASSIGN, BAND, BAND_ASSIGN, BOR, BOR_ASSIGN,
                BSR, BSR_ASSIGN, BXOR, BXOR_ASSIGN, COLON, DIV, DIV_ASSIGN,
                EQUAL, GE, GT, LAND, LCURLY, LE, LITERAL_CATCH,
                LITERAL_DO, LITERAL_ELSE, LITERAL_FINALLY, LITERAL_FOR,
                LITERAL_IF, LITERAL_RETURN, LITERAL_SWITCH, LITERAL_SYNCHRONIZED,
                LITERAL_TRY, LITERAL_WHILE, LOR, LT, MINUS, MINUS_ASSIGN,
                MOD, MOD_ASSIGN, NOT_EQUAL, PLUS, PLUS_ASSIGN, QUESTION,
                RCURLY, SL, SLIST, SL_ASSIGN, SR, SR_ASSIGN, STAR, STAR_ASSIGN,
                TYPE_EXTENSION_AND"/>
            <property name="allowEmptyConstructors" value="true"/>
            <property name="allowEmptyMethods" value="true"/>
            <property name="allowEmptyTypes" value="true"/>
            <property name="allowEmptyLoops" value="true"/>
        </module>
        <module name="WhitespaceAfter"/>
        <module name="NoWhitespaceBefore"/>
        <module name="GenericWhitespace"/>
        <!-- Không có khoảng trắng thừa ở cuối dòng -->
        <module name="Regexp">
            <property name="format" value="[ \t]+$"/>
            <property name="illegalPattern" value="true"/>
            <property name="message" value="Trailing whitespace"/>
        </module>

        <!-- ==================== BLOCKS ==================== -->
        <!-- Bắt buộc dùng {} cho if/else/for/while/do -->
        <module name="NeedBraces"/>
        <module name="LeftCurly"/>
        <module name="RightCurly"/>
        <!-- Không có block rỗng (trừ catch có comment) -->
        <module name="EmptyBlock">
            <property name="option" value="text"/>
        </module>
        <module name="EmptyCatchBlock">
            <property name="exceptionVariableName" value="expected|ignore"/>
        </module>

        <!-- ==================== CODING ==================== -->
        <!-- Không khai báo nhiều biến trên 1 dòng -->
        <module name="MultipleVariableDeclarations"/>
        <!-- Mỗi dòng chỉ có 1 câu lệnh -->
        <module name="OneStatementPerLine"/>
        <!-- Không dùng == để so sánh String -->
        <module name="StringLiteralEquality"/>
        <!-- Không có fall-through trong switch mà không có comment -->
        <module name="FallThrough"/>
        <!-- Override phải có @Override -->
        <module name="MissingOverride"/>
        <!-- Không khai báo biến cục bộ che khuất biến ngoài -->
        <module name="HiddenField">
            <property name="ignoreConstructorParameter" value="true"/>
            <property name="ignoreSetter" value="true"/>
        </module>
        <!-- Không viết số ma thuật (magic number) -->
        <module name="MagicNumber">
            <property name="ignoreNumbers" value="-1, 0, 1, 2"/>
            <property name="ignoreAnnotation" value="true"/>
            <property name="ignoreHashCodeMethod" value="true"/>
        </module>

        <!-- ==================== JAVADOC ==================== -->
        <module name="JavadocMethod">
            <property name="accessModifiers" value="private"/>
            <property name="allowMissingParamTags" value="true"/>
            <property name="allowMissingReturnTag" value="true"/>
        </module>
        <module name="MissingJavadocMethod">
            <property name="scope" value="nothing"/>
        </module>
        <module name="MissingJavadocType">
            <property name="scope" value="nothing"/>
        </module>

    </module>
</module>
