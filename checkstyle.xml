<?xml version="1.0"?>
<!DOCTYPE module PUBLIC "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
    "https://checkstyle.org/dtds/configuration_1_3.dtd">

<!--
    Google Java Style Guide — Checkstyle Configuration
    Ref: https://google.github.io/styleguide/javaguide.html
    severity="error" => mọi vi phạm đều FAIL BUILD (không chỉ warning)
-->
<module name="Checker">
    <property name="severity" value="error"/>
    <property name="fileExtensions" value="java"/>

    <!-- [4.2] Không dùng tab — chỉ dùng spaces -->
    <module name="FileTabCharacter">
        <property name="eachLine" value="true"/>
    </module>

    <!-- [4.4] Độ dài dòng tối đa 120 ký tự (nới rộng hơn Google 100 để tương thích codebase) -->
    <module name="LineLength">
        <property name="max" value="120"/>
        <!-- Bỏ qua dòng package/import và URL -->
        <property name="ignorePattern"
            value="^package\s|^import\s|^\s*\*\s*(https?://|@)"/>
    </module>

    <!-- Không để trailing whitespace cuối dòng -->
    <module name="RegexpSingleline">
        <property name="format" value="\s+$"/>
        <property name="minimum" value="0"/>
        <property name="maximum" value="0"/>
        <property name="message" value="Dòng có khoảng trắng thừa ở cuối (trailing whitespace)."/>
    </module>

    <!-- Hỗ trợ @SuppressWarnings("checkstyle:...") trong code -->
    <module name="SuppressWarningsFilter"/>

    <module name="TreeWalker">

        <!-- ===== NAMING CONVENTIONS [5] ===== -->

        <!-- [5.2.1] Package: chữ thường, không underscore -->
        <module name="PackageName">
            <property name="format" value="^[a-z]+(\.[a-z][a-z0-9]*)*$"/>
        </module>

        <!-- [5.2.2] Class/Interface/Enum: UpperCamelCase -->
        <module name="TypeName"/>

        <!-- [5.2.3] Method: lowerCamelCase -->
        <module name="MethodName"/>

        <!-- [5.2.4] Constant (static final): UPPER_SNAKE_CASE -->
        <module name="ConstantName"/>

        <!-- [5.2.5] Non-constant field, tham số, biến cục bộ: lowerCamelCase -->
        <module name="MemberName"/>
        <module name="ParameterName"/>
        <module name="LocalVariableName"/>
        <module name="StaticVariableName"/>

        <!-- ===== IMPORTS [3.3] ===== -->

        <!-- [3.3.1] Cấm wildcard import: import java.util.* -->
        <module name="AvoidStarImport"/>

        <!-- Import trùng lặp -->
        <module name="RedundantImport"/>

        <!-- Import không được dùng -->
        <module name="UnusedImports">
            <property name="processJavadoc" value="false"/>
        </module>

        <!-- ===== BRACES [4.1] ===== -->

        <!-- [4.1.1] Luôn dùng {} cho if/else/for/while/do -->
        <module name="NeedBraces"/>

        <!-- [4.1.2] Dấu { ở cuối dòng (K&R style) -->
        <module name="LeftCurly"/>

        <!-- [4.1.3] Dấu } đứng riêng một dòng, ngoại trừ else/catch/finally -->
        <module name="RightCurly"/>

        <!-- ===== WHITESPACE [4.6] ===== -->

        <!-- Khoảng trắng quanh toán tử, từ khóa -->
        <module name="WhitespaceAround">
            <property name="allowEmptyConstructors" value="true"/>
            <property name="allowEmptyMethods" value="true"/>
            <property name="allowEmptyTypes" value="true"/>
            <property name="allowEmptyLambdas" value="true"/>
            <property name="allowEmptyCatches" value="true"/>
        </module>

        <!-- Khoảng trắng sau dấu phẩy, chấm phẩy, ép kiểu -->
        <module name="WhitespaceAfter"/>

        <!-- Không có khoảng trắng trước dấu ; , -->
        <module name="NoWhitespaceBefore"/>

        <!-- Không có khoảng trắng thừa trong parentheses -->
        <module name="ParenPad"/>

        <!-- Generic type <T>: không có khoảng trắng -->
        <module name="GenericWhitespace"/>

        <!-- ===== INDENTATION [4.2] ===== -->

        <!-- Thụt đầu dòng 4 spaces (điều chỉnh phù hợp codebase hiện tại) -->
        <module name="Indentation">
            <property name="basicOffset" value="4"/>
            <property name="braceAdjustment" value="0"/>
            <property name="caseIndent" value="4"/>
            <property name="throwsIndent" value="8"/>
            <property name="lineWrappingIndentation" value="8"/>
            <property name="arrayInitIndent" value="4"/>
        </module>

        <!-- ===== CODING PRACTICES ===== -->

        <!-- Không để khối catch/finally/else rỗng hoàn toàn (không có comment) -->
        <module name="EmptyCatchBlock">
            <!-- Cho phép biến tên "ignored" hoặc "expected" -->
            <property name="exceptionVariableName" value="expected|ignored"/>
        </module>

        <!-- Mỗi dòng chỉ một câu lệnh -->
        <module name="OneStatementPerLine"/>

        <!-- Không khai báo nhiều biến trên một dòng: int a, b; -->
        <module name="MultipleVariableDeclarations"/>

        <!-- Kiểu mảng phải viết sau tên kiểu: String[] args, không phải String args[] -->
        <module name="ArrayTypeStyle"/>

        <!-- switch phải có default case -->
        <module name="MissingSwitchDefault"/>

        <!-- Cảnh báo fall-through trong switch (phải có comment "falls through") -->
        <module name="FallThrough"/>

        <!-- Long literal phải dùng L hoa: 100L, không phải 100l -->
        <module name="UpperEll"/>

        <!-- Thứ tự modifier: public static final... -->
        <module name="ModifierOrder"/>

        <!-- Không khai báo class/field/method trùng tên với lớp cha -->
        <module name="HiddenField">
            <property name="ignoreConstructorParameter" value="true"/>
            <property name="ignoreSetter" value="true"/>
            <property name="setterCanReturnItsClass" value="true"/>
        </module>

        <!-- Hỗ trợ @SuppressWarnings annotation bên trong TreeWalker -->
        <module name="SuppressWarningsHolder"/>

    </module>
</module>
