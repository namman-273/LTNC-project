<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0
             http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <groupId>com.auction.app</groupId>
    <artifactId>AuctionSystem</artifactId>
    <version>1.0-SNAPSHOT</version>
    <packaging>jar</packaging>

    <properties>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
        <project.reporting.outputEncoding>UTF-8</project.reporting.outputEncoding>
        <maven.compiler.source>17</maven.compiler.source>
        <maven.compiler.target>17</maven.compiler.target>
        <!-- Phiên bản plugin được ghim cứng để build tái lặp (reproducible) -->
        <checkstyle.plugin.version>3.3.1</checkstyle.plugin.version>
        <checkstyle.core.version>10.12.1</checkstyle.core.version>
        <jacoco.version>0.8.11</jacoco.version>
        <javafx.version>17.0.8</javafx.version>
        <junit.version>5.10.0</junit.version>
        <surefire.version>3.1.2</surefire.version>
        <!-- Ngưỡng coverage tối thiểu: 60% instruction coverage -->
        <jacoco.minimum.coverage>0.60</jacoco.minimum.coverage>
    </properties>

    <!-- ===== DEPENDENCIES ===== -->
    <dependencies>
        <!-- JavaFX UI -->
        <dependency>
            <groupId>org.openjfx</groupId>
            <artifactId>javafx-controls</artifactId>
            <version>${javafx.version}</version>
        </dependency>
        <dependency>
            <groupId>org.openjfx</groupId>
            <artifactId>javafx-fxml</artifactId>
            <version>${javafx.version}</version>
        </dependency>

        <!-- JSON serialization -->
        <dependency>
            <groupId>com.google.code.gson</groupId>
            <artifactId>gson</artifactId>
            <version>2.10.1</version>
        </dependency>

        <!-- JUnit 5 — chỉ dùng trong phạm vi test -->
        <dependency>
            <groupId>org.junit.jupiter</groupId>
            <artifactId>junit-jupiter-api</artifactId>
            <version>${junit.version}</version>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>org.junit.jupiter</groupId>
            <artifactId>junit-jupiter-engine</artifactId>
            <version>${junit.version}</version>
            <scope>test</scope>
        </dependency>
        <!-- Hỗ trợ test tham số hóa (parameterized tests) -->
        <dependency>
            <groupId>org.junit.jupiter</groupId>
            <artifactId>junit-jupiter-params</artifactId>
            <version>${junit.version}</version>
            <scope>test</scope>
        </dependency>
    </dependencies>

    <!-- ===== BUILD PLUGINS ===== -->
    <build>
        <plugins>

            <!-- 1. COMPILER: tường minh encoding UTF-8, tương thích JDK 17 -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
                <version>3.11.0</version>
                <configuration>
                    <encoding>UTF-8</encoding>
                    <source>17</source>
                    <target>17</target>
                    <!-- Bật warning đầy đủ khi compile -->
                    <compilerArgs>
                        <arg>-Xlint:all</arg>
                        <arg>-Xlint:-processing</arg>
                    </compilerArgs>
                </configuration>
            </plugin>

            <!-- 2. SUREFIRE: chạy JUnit 5, inject JaCoCo agent qua @{argLine} -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-surefire-plugin</artifactId>
                <version>${surefire.version}</version>
                <configuration>
                    <!--
                        @{argLine} PHẢI có mặt để JaCoCo inject agent.
                        Nếu thiếu, report coverage sẽ luôn = 0%.
                        -Djava.awt.headless=true: chạy test không cần màn hình (cho CI).
                    -->
                    <argLine>
                        @{argLine}
                        -Djava.awt.headless=true
                        --add-opens java.base/java.lang=ALL-UNNAMED
                        --add-opens java.base/java.util=ALL-UNNAMED
                    </argLine>
                    <!-- Hiện log test trên console CI -->
                    <useFile>false</useFile>
                </configuration>
            </plugin>

            <!-- 3. CHECKSTYLE: enforce Google Style Guide, FAIL BUILD nếu vi phạm -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-checkstyle-plugin</artifactId>
                <version>${checkstyle.plugin.version}</version>
                <dependencies>
                    <!-- Ghim phiên bản Checkstyle core để kết quả nhất quán -->
                    <dependency>
                        <groupId>com.puppycrawl.tools</groupId>
                        <artifactId>checkstyle</artifactId>
                        <version>${checkstyle.core.version}</version>
                    </dependency>
                </dependencies>
                <configuration>
                    <configLocation>checkstyle.xml</configLocation>
                    <encoding>UTF-8</encoding>
                    <consoleOutput>true</consoleOutput>
                    <!--
                        FIX: failOnViolation=true + severity="error" trong checkstyle.xml
                        => Build THỰC SỰ fail khi có vi phạm.
                        (failsOnError chỉ fail khi Checkstyle crash, không phải khi có violation)
                    -->
                    <failOnViolation>true</failOnViolation>
                    <violationSeverity>error</violationSeverity>
                    <!-- Bỏ qua file Main.java rỗng (xóa file này khỏi project là tốt nhất) -->
                    <excludes>**/Main.java</excludes>
                    <linkXRef>false</linkXRef>
                </configuration>
                <executions>
                    <execution>
                        <id>validate-style</id>
                        <!-- Chạy ở phase verify (sau compile, trước install) -->
                        <phase>verify</phase>
                        <goals>
                            <goal>check</goal>
                        </goals>
                    </execution>
                </executions>
            </plugin>

            <!-- 4. JACOCO: đo coverage, FAIL BUILD nếu dưới 60% -->
            <plugin>
                <groupId>org.jacoco</groupId>
                <artifactId>jacoco-maven-plugin</artifactId>
                <version>${jacoco.version}</version>
                <executions>
                    <!-- Bước 1: Chuẩn bị agent trước khi test chạy -->
                    <execution>
                        <id>prepare-agent</id>
                        <goals>
                            <goal>prepare-agent</goal>
                        </goals>
                    </execution>
                    <!-- Bước 2: Tạo HTML/XML report sau khi test xong -->
                    <execution>
                        <id>report</id>
                        <phase>test</phase>
                        <goals>
                            <goal>report</goal>
                        </goals>
                    </execution>
                    <!-- Bước 3: Kiểm tra ngưỡng coverage — FAIL nếu < 60% -->
                    <execution>
                        <id>check-coverage</id>
                        <phase>verify</phase>
                        <goals>
                            <goal>check</goal>
                        </goals>
                        <configuration>
                            <rules>
                                <rule>
                                    <element>BUNDLE</element>
                                    <limits>
                                        <limit>
                                            <counter>INSTRUCTION</counter>
                                            <value>COVEREDRATIO</value>
                                            <minimum>${jacoco.minimum.coverage}</minimum>
                                        </limit>
                                    </limits>
                                </rule>
                            </rules>
                            <!--
                                Loại trừ các class JavaFX (Controller/View/MainApp)
                                khỏi tính coverage vì chúng cần màn hình thật để test.
                                Logic nghiệp vụ (model/service/util) vẫn bị tính.
                            -->
                            <excludes>
                                <exclude>com/auction/MainApp.class</exclude>
                                <exclude>com/auction/Main.class</exclude>
                                <exclude>com/auction/views/**</exclude>
                                <exclude>com/auction/controllers/**</exclude>
                            </excludes>
                        </configuration>
                    </execution>
                </executions>
            </plugin>

            <!-- 5. JAVAFX MAVEN PLUGIN: chạy ứng dụng với mvn javafx:run -->
            <plugin>
                <groupId>org.openjfx</groupId>
                <artifactId>javafx-maven-plugin</artifactId>
                <version>0.0.8</version>
                <configuration>
                    <mainClass>com.auction.MainApp</mainClass>
                    <!-- Đảm bảo JavaFX modules được load đúng -->
                    <options>
                        <option>--add-opens</option>
                        <option>javafx.graphics/com.sun.javafx.application=ALL-UNNAMED</option>
                    </options>
                </configuration>
            </plugin>

        </plugins>
    </build>

    <!-- ===== REPORTING: tạo site report cho Checkstyle và JaCoCo ===== -->
    <reporting>
        <plugins>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-checkstyle-plugin</artifactId>
                <version>${checkstyle.plugin.version}</version>
                <configuration>
                    <configLocation>checkstyle.xml</configLocation>
                </configuration>
            </plugin>
        </plugins>
    </reporting>

</project>
